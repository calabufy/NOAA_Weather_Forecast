# .env.example — шаблон переменных окружения (реальный .env в репозиторий не коммитится).
# Скопировать в .env и заполнить.
#
# BOT_TOKEN        — токен Telegram-бота от BotFather (Фаза 4).
# ALLOWED_CHAT_IDS — список chat_id через запятую; бот отвечает только им (allowlist).
# DB_PATH          — путь к файлу SQLite (в Docker указывает на volume) (Фаза 2).
#
# HTTP_CONTACT     — контакт для заголовка User-Agent (api.weather.gov/NOAA требуют
#                    осмысленный User-Agent, иначе 403).
# HTTP_USER_AGENT  — можно переопределить строку User-Agent целиком (иначе собирается
#                    из имени приложения и HTTP_CONTACT).

BOT_TOKEN=8336402698:AAFuRjwbrPxYhPOvJBf7pUFtA1gQTFwpkx4
ALLOWED_CHAT_IDS=7550886792,896770511
DB_PATH=weather.db
HTTP_CONTACT=adamkeroshi@gmail.com
