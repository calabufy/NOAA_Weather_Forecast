# .env.example — шаблон переменных окружения (реальный .env в репозиторий не коммитится).
# Скопировать в .env и заполнить.
#
# BOT_TOKEN        — токен Telegram-бота от BotFather (Фаза 4).
# ALLOWED_CHAT_IDS — список chat_id через запятую; бот отвечает только им (allowlist).
# DB_PATH          — путь к файлу SQLite (в Docker указывает на volume) (Фаза 2).
#
# HTTP_CONTACT     — контакт для заголовка User-Agent (api.weather.gov/NOAA требуют
#                    осмысленный User-Agent, иначе 403).
# HTTP_USER_AGENT  — можно переопределить строку User-Agent целиком (иначе собирается
#                    из имени приложения и HTTP_CONTACT).
#
# --- Yandex Cloud (Фаза 6: serverless) ---
# DB_BACKEND       — 'sqlite' (локально/тесты) или 'ydb' (Cloud Functions).
# YDB_ENDPOINT     — endpoint YDB Serverless (grpcs://ydb.serverless.yandexcloud.net:2135).
# YDB_DATABASE     — путь базы, вида /ru-central1/b1g.../etn... (консоль YC → база → Endpoint).
# TG_WEBHOOK_SECRET — случайная строка: scripts/set_webhook.py сообщает её Telegram,
#                    handler.bot_webhook отвергает запросы без неё.
# YC_SERVICE_ACCOUNT_ID — id сервисного аккаунта, под которым работают функции
#                    (роль ydb.editor); нужен scripts/deploy.ps1.
# Аутентификация YDB локально (для init/migrate): перед запуском задать
#   YDB_ACCESS_TOKEN_CREDENTIALS=$(yc iam create-token)  # либо ключ SA, см. README

BOT_TOKEN=123456789:PLACEHOLDER-get-from-BotFather
ALLOWED_CHAT_IDS=111111111,222222222
DB_PATH=weather.db
HTTP_CONTACT=you@example.com

DB_BACKEND=sqlite
YDB_ENDPOINT=grpcs://ydb.serverless.yandexcloud.net:2135
YDB_DATABASE=
TG_WEBHOOK_SECRET=
YC_SERVICE_ACCOUNT_ID=
